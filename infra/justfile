set shell := ["bash", "-euo", "pipefail", "-c"]
set dotenv-path := "../.env"

ssh_args  := "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"
repo_root := justfile_directory() / ".."
prod_tf   := justfile_directory() / "prod"

default:
    @just --list

# ── Prod (pln.sh) ─────────────────────────────────────────────────────
#
# Day-to-day lifecycle:
#   just prod-up          # terraform apply (hetzner + cloudflare)
#   just prod-bootstrap   # auto-install pln on nodes, form the mesh
#   just prod-seed        # seed apex + docs sites
#   just prod-upgrade     # bump pln on every node to the latest release
#   just prod-status
#
# Teardown:
#   just prod-down        # terraform destroy
#
# All recipes run under PLN_CONTEXT=prod. The ctx is an SSH-bridged admin
# handle — no local prod daemon required. `pln ctx add prod root@<host>`
# bootstraps the ctx.

# Provision hetzner nodes + cloudflare DNS + rules.
prod-up:
    cd {{ prod_tf }} && terraform init -input=false && terraform apply -auto-approve

# Destroy prod infrastructure. WARNING: terminates nodes, removes DNS.
prod-down:
    cd {{ prod_tf }} && terraform destroy

# Form the mesh. pln bootstrap ssh auto-installs pln via install.sh on
# any node that doesn't have it, then joins each to the mesh using the
# prod ctx's admin keys. --admin delegates signing authority to each
# prod node. Post-join, each node gets its static-http listener bound
# to :8080 (CF origin rule routes proxied traffic there).
prod-bootstrap:
    #!/usr/bin/env bash
    set -euo pipefail
    export PLN_CONTEXT="prod"
    cd {{ prod_tf }}

    echo "forming mesh via pln bootstrap ssh..."
    terraform output -raw bootstrap_targets | pln bootstrap ssh --admin -

    echo "configuring static-http :8080 on each node..."
    # `|| [ -n "$line" ]` catches the final line when terraform output
    # omits its trailing newline — otherwise read drops it silently.
    while IFS= read -r line || [ -n "$line" ]; do
      host=${line##*=root@}
      ssh {{ ssh_args }} "root@$host" "pln --dir /var/lib/pln set static-http :8080 && systemctl restart pln"
      echo "  $host ready"
    done < <(terraform output -raw bootstrap_targets)

# Seed the apex landing page + install.sh and the docs stub.
#
# The apex bundle is assembled in a tmp dir: the static HTML from
# web/apex/ plus install.sh with the latest release tag baked in (same
# sed goreleaser does at release time). Seeds flow through the prod ctx
# directly to the target daemon — no laptop CAS involved.
prod-seed:
    #!/usr/bin/env bash
    set -euo pipefail
    export PLN_CONTEXT="prod"
    cd {{ repo_root }}
    VERSION=$(git describe --tags --abbrev=0)
    APEX_BUNDLE=$(mktemp -d)
    trap 'rm -rf "$APEX_BUNDLE"' EXIT
    cp -r web/apex/. "$APEX_BUNDLE"/
    sed "s|^VERSION=\"__VERSION__\"|VERSION=\"$VERSION\"|" scripts/install.sh > "$APEX_BUNDLE/install.sh"
    chmod +x "$APEX_BUNDLE/install.sh"
    pln seed "$APEX_BUNDLE" pln.sh --min-replicas 2
    pln seed web/docs docs.pln.sh --min-replicas 2

# Upgrade pln on every node to the latest release. `pln daemon upgrade`
# is localOnly, so it has to run on each node directly — can't go through
# the prod ctx. The .deb postinstall restarts an active service.
prod-upgrade:
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ prod_tf }}
    while IFS= read -r line || [ -n "$line" ]; do
      host=${line##*=root@}
      echo "upgrading $host..."
      ssh {{ ssh_args }} "root@$host" "pln daemon upgrade"
    done < <(terraform output -raw bootstrap_targets)

# Mesh status via the prod ctx.
prod-status:
    PLN_CONTEXT=prod pln status

# SSH into a prod node by name (eu or us).
prod-ssh name="eu":
    #!/usr/bin/env bash
    set -euo pipefail
    HOST=$(cd {{ prod_tf }} && terraform output -json node_hostnames | jq -r ".[\"{{ name }}\"]")
    exec ssh {{ ssh_args }} "root@$HOST"
