{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "type": "volkovlabs-echarts-panel",
      "title": "Mesh Topology",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pollen_workload_load{workload=\"ingest\"}",
          "legendFormat": "{{node}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "D",
          "expr": "pollen_node_info",
          "legendFormat": "{{name}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "E",
          "expr": "pollen_workload_claim{workload=\"ingest\"}",
          "legendFormat": "{{node}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "G",
          "expr": "pollen_workload_load{workload=\"terminal\"}",
          "legendFormat": "{{node}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "H",
          "expr": "pollen_workload_claim{workload=\"terminal\"}",
          "legendFormat": "{{node}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "renderer": "canvas",
        "editor": {
          "format": "auto",
          "height": 600
        },
        "getOption": "\nconst coords = {\n  root: [-0.13, 51.51], use: [-77.46, 38.95], usw: [-122.68, 45.52],\n  euw: [-6.26, 53.35], eun: [18.07, 59.33], euc: [8.68, 50.11],\n  tok: [139.69, 35.68], sgp: [103.85, 1.29], syd: [151.21, -33.87],\n  mum: [72.88, 19.08], sao: [-46.63, -23.55],\n};\nconst colours = { ingest: '#3274D9', terminal: '#FF9830' };\nconst loadRef = { A: 'ingest', G: 'terminal' };\nconst claimRef = { E: 'ingest', H: 'terminal' };\n\nif (!context.panel.__mapLoaded) {\n  const xhr = new XMLHttpRequest();\n  xhr.open('GET', '/public/gazetteer/world.json', false);\n  xhr.send();\n  if (xhr.status === 200) {\n    context.echarts.registerMap('world', JSON.parse(xhr.responseText));\n    context.panel.__mapLoaded = true;\n  }\n}\n\nconst loadBuckets = { ingest: [], terminal: [] };\nconst claimBuckets = { ingest: [], terminal: [] };\nconst nodes = [];\nconst seen = new Set();\n\nfor (const s of context.panel.data.series) {\n  const valField = s.fields.find(f => f.type === 'number');\n  if (!valField || !valField.values.length) continue;\n\n  if (s.refId === 'D') {\n    const name = valField.labels?.name || '';\n    const c = coords[name];\n    if (c && !seen.has(name)) {\n      seen.add(name);\n      nodes.push({ name: name, value: [c[0], c[1]] });\n    }\n    continue;\n  }\n\n  const node = valField.labels?.node || '';\n  const c = coords[node];\n  if (!c) continue;\n\n  if (loadRef[s.refId]) {\n    const load = valField.values[0] || 0;\n    if (load > 0) {\n      loadBuckets[loadRef[s.refId]].push({ name: node, value: [c[0], c[1], load] });\n    }\n  } else if (claimRef[s.refId]) {\n    const claimed = valField.values[0] || 0;\n    if (claimed > 0) {\n      claimBuckets[claimRef[s.refId]].push({ name: node, value: [c[0], c[1]] });\n    }\n  }\n}\n\nconst series = [{\n  name: 'nodes',\n  type: 'scatter',\n  coordinateSystem: 'geo',\n  symbolSize: 7,\n  itemStyle: { color: '#cfd2d6', opacity: 0.55, borderColor: '#ffffff', borderWidth: 1 },\n  z: 1,\n  data: nodes,\n}];\n\nfor (const [wl, data] of Object.entries(claimBuckets)) {\n  if (!data.length) continue;\n  series.push({\n    name: wl,\n    type: 'scatter',\n    coordinateSystem: 'geo',\n    symbolSize: 12,\n    itemStyle: { color: colours[wl], opacity: 0.55, borderColor: colours[wl], borderWidth: 1 },\n    z: 2,\n    data: data,\n  });\n}\n\nfor (const [wl, data] of Object.entries(loadBuckets)) {\n  if (!data.length) continue;\n  series.push({\n    name: wl + ' load',\n    type: 'effectScatter',\n    coordinateSystem: 'geo',\n    symbolSize: (val) => Math.min(Math.max(Math.sqrt(val[2]) * 5, 14), 50),\n    itemStyle: { color: colours[wl], opacity: 0.35 },\n    rippleEffect: { brushType: 'stroke', scale: 2.5, period: 4 },\n    z: 3,\n    data: data,\n  });\n}\n\nreturn {\n  backgroundColor: 'transparent',\n  geo: {\n    map: 'world',\n    roam: true,\n    silent: true,\n    center: [20, 20],\n    zoom: 1.3,\n    itemStyle: { areaColor: '#1a1a2e', borderColor: '#333' },\n    emphasis: { disabled: true },\n  },\n  tooltip: {\n    trigger: 'item',\n    formatter: (p) => {\n      if (p.seriesName === 'nodes') return '<b>' + p.name + '</b>';\n      if (p.value.length > 2) return '<b>' + p.seriesName + '</b><br/>' + p.name + ': ' + p.value[2].toFixed(1) + ' req/s';\n      return '<b>' + p.seriesName + '</b><br/>' + p.name + ' (idle)';\n    },\n  },\n  legend: {\n    data: ['ingest', 'terminal'],\n    textStyle: { color: '#ccc' },\n    bottom: 10,\n  },\n  series: series,\n};\n"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Replicas per Workload",
      "description": "Total replicas claimed across the cluster, per workload. Watch the autoscaler add replicas as load ramps.",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pollen_workload_replicas",
          "legendFormat": "{{name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "sum(pollen_workload_replicas)",
          "legendFormat": "total",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ingest"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3274D9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "terminal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9830"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#cfd2d6"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [4, 4]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Client-observed request rate (by region)",
      "description": "ok vs fail rate measured at the dedicated exerciser. One line per exerciser target — new lines appear as regions are added.",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (target) (rate(exerciser_calls_total{outcome=\"ok\"}[1m]))",
          "legendFormat": "{{target}} ok",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "sum by (target) (rate(exerciser_calls_total{outcome=\"fail\"}[1m]))",
          "legendFormat": "{{target}} fail",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never"
          },
          "mappings": [],
          "unit": "reqps"
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".* fail$"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]},
          {"matcher": {"id": "byName", "options": "euc ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#5794F2"}}]},
          {"matcher": {"id": "byName", "options": "eun ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#73BF69"}}]},
          {"matcher": {"id": "byName", "options": "euw ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#B877D9"}}]},
          {"matcher": {"id": "byName", "options": "mum ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#8AB8FF"}}]},
          {"matcher": {"id": "byName", "options": "sao ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FADE2A"}}]},
          {"matcher": {"id": "byName", "options": "sgp ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#00A699"}}]},
          {"matcher": {"id": "byName", "options": "syd ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FF7383"}}]},
          {"matcher": {"id": "byName", "options": "tok ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#37872D"}}]},
