    {
      "id": 20,
      "type": "timeseries",
      "title": "Client-observed request rate (by target)",
      "description": "ok vs fail rate measured by the dedicated exerciser. Shows what the client saw end-to-end, including any mesh/gate loss invisible to the server side.",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (target) (rate(exerciser_calls_total{outcome=\"ok\"}[1m]))",
          "legendFormat": "{{target}} ok",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "sum by (target) (rate(exerciser_calls_total{outcome=\"fail\"}[1m]))",
          "legendFormat": "{{target}} fail",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "C",
